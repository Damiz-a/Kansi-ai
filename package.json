{
  "name": "kansi-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n flask,next -c \"magenta,cyan\" \"npm run dev:flask\" \"npm run dev:next\"",
    "dev:flask": "cd .. && python -m flask --app kansi_ai/app.py run --debug --port 5000",
    "dev:next": "cd frontend && npm run dev",
    "start:flask": "python app.py",
    "start:next": "cd frontend && npm start",
    "install:all": "npm install && cd frontend && npm install",
    "build": "cd frontend && npm run build"
  },
  "dependencies": {
    "concurrently": "^9.0.0"
  }
}
