# ── Flask / Python backend ────────────────────────────────────────────────────
KANSI_SECRET_KEY=your-flask-secret-key-here

# Comma-separated list of trusted frontend origins (no trailing slash)
KANSI_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# URL that Flask redirects browsers to (the Next.js frontend)
FRONTEND_URL=http://localhost:3000

# Set to true to show password-reset links in the API response (dev only)
KANSI_SHOW_RESET_LINKS=false

# Optional: enable demo Google OAuth endpoint
KANSI_ENABLE_DEMO_GOOGLE_AUTH=true

KANSI_DEBUG=true
PORT=5000

# ── Clerk JWT validation (hybrid auth) ───────────────────────────────────────
# Obtain from: Clerk dashboard → API Keys → Advanced → JWKS endpoint
# Format: https://<your-clerk-frontend-api>/.well-known/jwks.json
CLERK_JWKS_URL=

# ── Next.js / Clerk (frontend) ────────────────────────────────────────────────
# Obtain from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs (defaults work for local dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
