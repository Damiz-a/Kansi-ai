KANSI_ENV=production
KANSI_SECRET_KEY=replace-with-a-long-random-secret
KANSI_SITE_URL=https://your-domain.example
KANSI_SESSION_COOKIE_SECURE=true
KANSI_TRUSTED_ORIGINS=https://your-domain.example
KANSI_WEBHOOK_SECRET=replace-with-a-different-long-random-secret
KANSI_ALLOWED_FETCH_HOSTS=findahelpline.com
KANSI_PASSWORD_RESET_TTL_MINUTES=30
KANSI_MAX_CONTENT_LENGTH=65536
KANSI_LOG_LEVEL=INFO
